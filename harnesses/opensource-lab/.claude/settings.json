{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agent": "coordinator",
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(pwd)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(which *)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(bun --version)",
      "Bash(python3 --version)",
      "Bash(uv --version)",
      "Bash(git --version)",
      "Bash(bws --version)",
      "Bash(jq *)",
      "Bash(tree *)",
      "Bash(du -sh *)",
      "Bash(df -h)",
      "Bash(scripts/reverify.sh:*)",
      "Bash(scripts/archive.sh:*)",
      "Bash(scripts/upstream-digest.sh:*)",
      "Bash(scripts/port-registry.sh:*)",
      "Bash(scripts/similarity-check.sh:*)",
      "Bash(scripts/qa-gate.sh:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(sudo *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/qa-gate.sh",
            "description": "Lab hygiene: warn if registry / progress.tsv / project isolation drifted"
          }
        ]
      }
    ]
  }
}
