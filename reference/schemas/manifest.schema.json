{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/claude-harness-blueprint/manifest.schema.json",
  "title": "Claude Harness Blueprint Manifest",
  "description": "manifest.json 的 Schema 定义，描述仓库中的模板、示例和脚本。",
  "type": "object",
  "required": ["name", "version", "templates"],
  "properties": {
    "name": {
      "type": "string",
      "description": "仓库名称"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "语义化版本号"
    },
    "description": {
      "type": "string",
      "description": "仓库简短描述"
    },
    "license": {
      "type": "string",
      "description": "开源协议"
    },
    "templates": {
      "type": "array",
      "description": "可用的 Harness 模板列表",
      "items": {
        "$ref": "#/$defs/template"
      },
      "minItems": 1
    },
    "examples": {
      "type": "array",
      "description": "端到端示例列表",
      "items": {
        "$ref": "#/$defs/example"
      }
    },
    "scripts": {
      "type": "object",
      "description": "辅助脚本路径",
      "properties": {
        "init": { "type": "string" },
        "overlay": { "type": "string" },
        "upgrade": { "type": "string" },
        "verify": { "type": "string" }
      }
    }
  },
  "$defs": {
    "template": {
      "type": "object",
      "required": ["id", "name", "path", "roles"],
      "properties": {
        "id": {
          "type": "string",
          "description": "模板标识符，用于脚本引用"
        },
        "name": {
          "type": "string",
          "description": "模板显示名称"
        },
        "description": {
          "type": "string",
          "description": "模板用途描述"
        },
        "path": {
          "type": "string",
          "description": "相对于仓库根目录的路径"
        },
        "roles": {
          "type": "array",
          "description": "模板中的角色列表",
          "items": {
            "type": "string"
          },
          "minItems": 2
        },
        "typical_use": {
          "type": "string",
          "description": "典型使用场景"
        }
      }
    },
    "example": {
      "type": "object",
      "required": ["id", "name", "path"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "template": {
          "type": "string",
          "description": "基于哪个模板"
        }
      }
    }
  }
}
